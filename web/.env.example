# Site
NEXT_PUBLIC_SITE_URL=https://eddie.kartersanamo.com

# Database (MySQL)
# Local: mysql://USER:PASSWORD@localhost:3306/eddie_youman
# Docker on same host as MySQL: use host.docker.internal or the host LAN IP instead of localhost
DATABASE_URL="mysql://user:password@host.docker.internal:3306/eddie_youman"

# File uploads (job photos) — not stored in the database
# Local: ./data   Docker: /app/data (mounted volume in deploy.sh)
DATA_DIR=./data

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://eddie.kartersanamo.com

# Admin seed (used by npm run db:seed on first deploy only)
# Comma-separated emails; ADMIN_PASSWORD is a one-time temporary password per account
# (must be changed on first login). Re-running seed does not reset existing passwords.
ADMIN_EMAILS=eddie@eddieyouman.com
ADMIN_PASSWORD=ChangeMeNow!

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM="Eddie Youman Services <noreply@your-mailgun-domain>"
CONTACT_TO_EMAIL=eddie@eddieyouman.com

# Stripe (payments on completed jobs)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Rate limits
CONTACT_RATE_LIMIT_PER_HOUR=5

# Cron (daily — Bearer token)
CRON_SECRET=
